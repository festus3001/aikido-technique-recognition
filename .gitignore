# OS
.DS_Store

# Python
__pycache__/
*.pyc
*.egg-info/
.pytest_cache/

# fetch / build caches
.cache/
**/.cache/

# regenerable build artifacts (rebuild with atr-crawler-db)
*.sqlite
# reviewed taxonomy is a projection of reviews.json (rebuild with atr-review-merge)
data/taxonomy/techniques_reviewed.json

# documentation build outputs (rebuild with atr-publish; copied to Google Drive)
dist/
# docx are built from markdown by tools/publish; markdown is the source of truth
*.docx
# Google Drive OAuth client secret + cached token (never commit credentials)
.gdrive/
**/.gdrive/

# conda environments are never stored in-tree
envs/

# resources/ (scanned books, extracted keyframe images) are local-first / DVC-tracked
# and copyrighted reproductions -- excluded via resources/.gitignore, never committed.
# data/ JSON outputs are committed as the structured deliverable; the .sqlite is not.
