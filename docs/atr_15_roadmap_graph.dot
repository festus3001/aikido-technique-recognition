// ATR roadmap dependency graph -- source of truth.
// Render with: python docs/atr_15_roadmap_build.py  (writes atr_15_roadmap_graph.svg
// with the status legend composed below). Node ids carry the track (A..G).
digraph roadmap {
  rankdir=LR; ranksep=1.0; nodesep=0.3; compound=true; labelloc="t"; fontname="Helvetica";
  label=<<B><FONT POINT-SIZE="26">ATR</FONT></B>  <FONT POINT-SIZE="12" COLOR="#666666">Aikido Technique Recognition &#183; roadmap (dependency graph)</FONT>>;
  node [shape=box, style="rounded,filled", fontname="Helvetica", fontsize=10, fillcolor="#eeeeee", color="#999999"];
  edge [color="#aab0b6", arrowsize=0.6];

  subgraph cluster_A {
    label="A  Foundations"; labeljust="l"; fontsize=11; fontcolor="#666"; style="rounded"; color="#b0b0b0"; penwidth=1.3;
    A1 [label="A1 Conventions\n+ repo", fillcolor="#cfe8cf", color="#2e7d32"];
    A2 [label="A2 Governance\n+ consent", fillcolor="#fff3c4", color="#b8860b"];
    A3 [label="A3 Teacher\nonboarding", fillcolor="#fff3c4", color="#b8860b"];
  }
  subgraph cluster_B {
    label="B  Knowledge graph"; labeljust="l"; fontsize=11; fontcolor="#666"; style="rounded"; color="#b0b0b0"; penwidth=1.3;
    B1 [label="B1 Lineage +\nfederation map", fillcolor="#cfe8cf", color="#2e7d32"];
    B2 [label="B2 Reconcile\nduplicates", fillcolor="#fff3c4", color="#b8860b"];
    B3 [label="B3 Deepen\nlineage"];
  }
  subgraph cluster_C {
    label="C  Taxonomy + sources"; labeljust="l"; fontsize=11; fontcolor="#666"; style="rounded"; color="#b0b0b0"; penwidth=1.3;
    C1 [label="C1 Book ingestion\npipeline", fillcolor="#cfe8cf", color="#2e7d32"];
    C2 [label="C2 Saito corpus\ningested", fillcolor="#cfe8cf", color="#2e7d32"];
    C3 [label="C3 Observation\nprovenance", fillcolor="#cfe8cf", color="#2e7d32"];
    C4 [label="C4 Teacher\nreview", fillcolor="#fff3c4", color="#b8860b"];
    C5 [label="C5 Planned books\n(8: Yoshinkan,\nAikikai, Ki, USAF)", fillcolor="#cfe0f5", color="#1565c0"];
  }
  subgraph cluster_D {
    label="D  Movement language (AML)"; labeljust="l"; fontsize=11; fontcolor="#666"; style="rounded"; color="#b0b0b0"; penwidth=1.3;
    D1 [label="D1 AML spec", fillcolor="#cfe8cf", color="#2e7d32"];
    D2 [label="D2 Kineme\nalphabet", fillcolor="#cfe8cf", color="#2e7d32"];
    D3 [label="D3 Motif lexicon\nfrom books", fillcolor="#cfe0f5", color="#1565c0"];
    D4 [label="D4 Grammar +\nrenderer"]; D5 [label="D5 Kote-gaeshi\ntrial"]; D6 [label="D6 Kineme\ndetectors"];
  }
  subgraph cluster_E {
    label="E  Perception"; labeljust="l"; fontsize=11; fontcolor="#666"; style="rounded"; color="#b0b0b0"; penwidth=1.3;
    E1 [label="E1 Pose\nextraction"]; E2 [label="E2 Representation\n+ primitives"]; E3 [label="E3 Keyframe\nground truth"]; E4 [label="E4 Video ingestion\n+ agreements"];
  }
  subgraph cluster_F {
    label="F  Model"; labeljust="l"; fontsize=11; fontcolor="#666"; style="rounded"; color="#b0b0b0"; penwidth=1.3;
    F1 [label="F1 Labeled\nmotion dataset"]; F2 [label="F2 Parse model\n(slots)"]; F3 [label="F3 Deep\nembedding"]; F4 [label="F4 Evaluation\nset"];
  }
  subgraph cluster_G {
    label="G  Product"; labeljust="l"; fontsize=11; fontcolor="#666"; style="rounded"; color="#b0b0b0"; penwidth=1.3;
    G1 [label="G1 Player +\noverlay"]; G2 [label="G2 Live\nannotation"]; G3 [label="G3 Lookup demo\n(flagship)"];
    G4 [label="G4 Search:\nstructured"]; G5 [label="G5 Search:\nqualitative"]; G6 [label="G6 Teacher\nover time"]; G7 [label="G7 Contribution\nloop"]; G8 [label="G8 Compare\ndemo"];
  }

  A1 -> B1; A1 -> C1; A1 -> D1; A2 -> E4; A2 -> G7;
  B1 -> B2; B2 -> B3;
  C1 -> C2; C2 -> C3; C2 -> C4; C2 -> D3; C2 -> E3; C4 -> D3; C4 -> F1; C4 -> F2; C4 -> F4; C5 -> C2;
  D1 -> D2; D2 -> D3; D2 -> D4; D2 -> D6; D3 -> D5; D4 -> D5;
  E1 -> E2; E1 -> E3; E1 -> G1; E1 -> F1; E2 -> D6; E2 -> F1;
  B1 -> E4; B1 -> G4; E4 -> F1;
  F1 -> F2; F1 -> F3; F2 -> G2; F2 -> G3; F2 -> G4; D6 -> G2;
  G1 -> G2; G1 -> G3; C3 -> G4; C3 -> G6;
  F3 -> G5; G4 -> G5; G4 -> G8; G5 -> G6; G3 -> G7;
}
